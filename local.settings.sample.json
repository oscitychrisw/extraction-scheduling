import { app } from "@azure/functions";
import { employeeSchema } from "../shared/validation.js";
import { upsertEmployee, softDeleteEmployee } from "../shared/repository.js";
import { errorResponse, json } from "../shared/http.js";

app.http("createEmployee", {
  methods: ["POST"],
  authLevel: "anonymous",
  route: "employees",
  handler: async (request) => {
    try {
      const employee = employeeSchema.parse(await request.json());
      const saved = await upsertEmployee(employee);
      return json(200, saved);
    } catch (error) {
      return errorResponse(error, 400);
    }
  },
});

app.http("updateEmployee", {
  methods: ["PUT"],
  authLevel: "anonymous",
  route: "employees/{employeeId}",
  handler: async (request) => {
    try {
      const employee = employeeSchema.parse(await request.json());
      const saved = await upsertEmployee({ ...employee, id: request.params.employeeId });
      return json(200, saved);
    } catch (error) {
      return errorResponse(error, 400);
    }
  },
});

app.http("deleteEmployee", {
  methods: ["DELETE"],
  authLevel: "anonymous",
  route: "employees/{employeeId}",
  handler: async (request) => {
    try {
      await softDeleteEmployee(request.params.employeeId);
      return { status: 204 };
    } catch (error) {
      return errorResponse(error);
    }
  },
});
